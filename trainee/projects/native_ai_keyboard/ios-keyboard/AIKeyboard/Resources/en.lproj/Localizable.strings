"help.section.keyboard" = "Why doesn’t the keyboard show in Messages?";
"help.keyboard.intro" = "iOS never auto-selects a new third-party keyboard. Follow these steps.";
"help.keyboard.step1" = "1) Open the AI Keyboard app on your device at least once (the extension installs with the app).";
"help.keyboard.step2" = "2) Settings → General → Keyboard → Keyboards → Add New Keyboard → choose “AI Keyboard”.";
"help.keyboard.step3" = "3) Tap “AI Keyboard” in the list → turn on Allow Full Access (required for AI and session).";
"help.keyboard.step4" = "4) In Messages, tap the keyboard switcher in the bottom-left (often a globe icon). Cycle keyboards until “AI Keyboard” appears. The default is always Apple’s keyboard.";

"help.section.ai" = "AI (Supabase)";
"help.ai.intro" = "“Rewrite” calls your Supabase Edge project. No subscription in this build.";
"help.ai.step1" = "1) In this app’s Info (or build settings), set SupabaseProjectURL to your project root, e.g. https://YOUR_REF.supabase.co (no /functions/v1).";
"help.ai.step2" = "2) Open this app once and tap “Refresh session & device” so the URL and device token are saved for the keyboard.";
"help.ai.step3" = "3) Keep Allow Full Access enabled for the keyboard — otherwise network requests fail.";

